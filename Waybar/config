{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 10,

  "modules-left": [
    "custom/launcher",
    "tray"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "pulseaudio",
    "network",
    "battery"
  ],

  "clock": {
    "format": "  {:%H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  },

  "battery": {
    "format": "  {capacity}%",
    "format-charging": " {capacity}%",
    "warning": 30,
    "critical": 15
  },

  "network": {
    "format-wifi": "  {essid}",
    "format-ethernet": "󰈀  Connected",
    "format-disconnected": "⚠ Disconnected"
  },

  "pulseaudio": {
    "format": "  {volume}%",
    "format-muted": " Muted"
  },

  "tray": {
    "spacing": 10
  },

  "custom/launcher": {
    "format": "Menu ",
    "on-click": "rofi -show drun"
  },
}
